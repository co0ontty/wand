<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050403">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/qrBarcodeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_preview_scaling_strategy="centerCrop"
        app:zxing_scanner_layout="@layout/view_qr_scanner_camera"
        app:zxing_use_texture_view="false" />

    <com.wand.app.QrScannerOverlayView
        android:id="@+id/qrOverlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/qrCloseButton"
            style="@style/Wand.Scanner.IconButton"
            android:contentDescription="@string/scan_qr_close"
            app:icon="@drawable/ic_close_24" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scan_qr_title"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/scan_qr_prompt"
                android:textColor="#CCEDE5DC"
                android:textSize="13sp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/qrTorchButton"
            style="@style/Wand.Scanner.ToolButton"
            android:text="@string/scan_qr_torch_on"
            app:icon="@drawable/ic_flash_on_24"
            app:iconGravity="textStart" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/scanner_controls_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/qrFocusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/scanner_focus_dot"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/qrFocusStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/scan_qr_focus_starting"
                android:textColor="#EDE5DC"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
