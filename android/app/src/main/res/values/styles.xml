<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Custom MaterialAlertDialog theme: rounded, warm card, brand-coloured buttons -->
    <style name="Theme.Wand.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:colorBackground">@color/card_bg</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="materialAlertDialogBodyTextStyle">@style/Wand.Dialog.Body</item>
        <item name="materialAlertDialogTitleTextStyle">@style/Wand.Dialog.Title</item>

        <item name="buttonBarPositiveButtonStyle">@style/Wand.Dialog.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Wand.Dialog.Button.Neutral</item>
        <item name="buttonBarNeutralButtonStyle">@style/Wand.Dialog.Button.Neutral</item>

        <item name="shapeAppearanceOverlay">@style/Wand.Dialog.Shape</item>
        <item name="dialogCornerRadius">22dp</item>
        <item name="android:windowBackground">@drawable/dialog_background</item>
    </style>

    <style name="Wand.Dialog.Shape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">22dp</item>
    </style>

    <style name="Wand.Dialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Wand.Dialog.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="Wand.Dialog.Button.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="rippleColor">#33C5653D</item>
    </style>

    <style name="Wand.Dialog.Button.Neutral" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="rippleColor">#22C5653D</item>
    </style>

    <style name="Theme.Wand.Scanner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
    </style>

    <style name="Wand.Scanner.IconButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:padding">0dp</item>
        <item name="backgroundTint">#3D000000</item>
        <item name="cornerRadius">24dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">#FFFFFFFF</item>
        <item name="rippleColor">#33FFFFFF</item>
    </style>

    <style name="Wand.Scanner.ToolButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textColor">#FFFFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="backgroundTint">#3D000000</item>
        <item name="cornerRadius">22dp</item>
        <item name="iconPadding">6dp</item>
        <item name="iconTint">#FFFFFFFF</item>
        <item name="rippleColor">#33FFFFFF</item>
    </style>

</resources>
