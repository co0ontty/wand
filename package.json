{
  "name": "wand",
  "version": "0.2.0",
  "description": "Remote web coding controller for local CLI tools.",
  "type": "module",
  "bin": {
    "wand": "dist/cli.js"
  },
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "files": [
    "dist"
  ],
  "preferGlobal": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:copy-content",
    "build:copy-content": "cp -r src/web-ui/content dist/web-ui/",
    "dev": "tsx src/cli.ts web",
    "check": "tsc --noEmit -p tsconfig.json",
    "pre-release-test": "node scripts/pre-release-test.js",
    "test": "npm run pre-release-test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "keywords": [
    "cli",
    "web",
    "automation",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@types/cookie": "^0.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "express": "^4.21.2",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.14",
    "@types/ws": "^8.18.1",
    "playwright": "^1.58.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
