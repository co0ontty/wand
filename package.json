{
  "name": "@co0ontty/wand",
  "version": "1.21.9",
  "description": "A web terminal for local CLI tools like Claude.",
  "type": "module",
  "bin": {
    "wand": "dist/cli.js"
  },
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "files": [
    "dist"
  ],
  "preferGlobal": true,
  "scripts": {
    "build": "node scripts/bundle-wterm.js && tsc -p tsconfig.json && npm run build:copy-content",
    "build:copy-content": "cp -r src/web-ui/content dist/web-ui/",
    "dev": "tsx src/cli.ts web",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "TAG=$(git tag --sort=-v:refname --list 'v*' | head -1) && VER=${TAG#v} && npm version $VER --no-git-tag-version --allow-same-version && npm run build"
  },
  "keywords": [
    "cli",
    "web",
    "automation",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "@types/compression": "^1.8.1",
    "@types/cookie": "^0.6.0",
    "@types/multer": "^2.1.0",
    "@wterm/dom": "^0.1.8",
    "compression": "^1.8.1",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "neo-blessed": "^0.2.0",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.14",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
